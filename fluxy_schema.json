{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Fluxy SDUI Schema",
  "description": "Strict JSON Schema for generating Server-Driven UI via the Fluxy engine. Use this to ensure your UI generated code will perfectly map to Fluxy widgets.",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "enum": ["box", "text", "button", "image", "row", "column", "hero"],
      "description": "The base widget type to render."
    },
    "style": {
      "type": "object",
      "description": "Fluxy style descriptor.",
      "properties": {
        "padding": {
          "description": "Padding value. Either a number (all), an array of 2 numbers [vertical, horizontal], or an array of 4 numbers [L, T, R, B]",
          "oneOf": [
            { "type": "number" },
            { "type": "array", "items": { "type": "number" } }
          ]
        },
        "margin": {
          "description": "Margin value. Either a number (all), an array of 2 numbers [vertical, horizontal], or an array of 4 numbers [L, T, R, B]",
          "oneOf": [
            { "type": "number" },
            { "type": "array", "items": { "type": "number" } }
          ]
        },
        "width": { "type": ["number", "string"] },
        "height": { "type": ["number", "string"] },
        "backgroundColor": { "type": "string", "pattern": "^#?([0-9a-fA-F]{6}|[0-9a-fA-F]{8})$" },
        "color": { "type": "string", "pattern": "^#?([0-9a-fA-F]{6}|[0-9a-fA-F]{8})$" },
        "borderRadius": { "type": "number" },
        "border": {
          "type": "object",
          "properties": {
            "color": { "type": "string" },
            "width": { "type": "number" }
          }
        },
        "shadows": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "color": { "type": "string" },
              "blur": { "type": "number" },
              "x": { "type": "number" },
              "y": { "type": "number" }
            }
          }
        },
        "opacity": { "type": "number", "minimum": 0, "maximum": 1 },
        "alignment": {
          "type": "string",
          "enum": ["center", "topLeft", "topRight", "bottomLeft", "bottomRight", "centerLeft", "centerRight", "topCenter", "bottomCenter"]
        },
        "fontSize": { "type": "number" },
        "fontWeight": {
          "type": "string",
          "enum": ["bold", "w100", "w200", "w300", "w400", "w500", "w600", "w700", "w800", "w900"]
        },
        "letterSpacing": { "type": "number" },
        "lineHeight": { "type": "number" },
        "fontFamily": { "type": "string" },
        "textAlign": {
          "type": "string",
          "enum": ["center", "end", "justify", "left", "right", "start"]
        }
      }
    },
    "onTap": {
      "type": "string",
      "description": "Action payload. Prefix with \"navigate:\", \"toast:\", \"update:\", or \"print:\""
    },
    "action": {
      "type": "string",
      "description": "Alias for onTap."
    },
    "data": {
      "type": "string",
      "description": "Text content. Applicable for 'text' type. Surround text with curly braces like {user.name} for data context interpolation."
    },
    "label": {
      "type": "string",
      "description": "Button label. Applicable for 'button' type."
    },
    "url": {
      "type": "string",
      "description": "Image URL. Applicable for 'image' type. Supports {var} interpolation."
    },
    "fit": {
      "type": "string",
      "enum": ["contain", "cover", "fill", "fitWidth", "fitHeight"],
      "description": "Applicable for 'image' type."
    },
    "tag": {
      "type": "string",
      "description": "Hero tag. Applicable for 'hero' type."
    },
    "gap": {
      "type": "number",
      "description": "Spacing between children. Applicable for 'row' and 'column' types."
    },
    "child": {
      "$ref": "#"
    },
    "children": {
      "type": "array",
      "items": {
        "$ref": "#"
      }
    }
  },
  "required": ["type"]
}
